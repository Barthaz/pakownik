{
  "expo": {
    "name": "Pakownik",
    "slug": "pakownik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pakownik",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pakownik.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.pakownik.app",
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://pakownik.vercel.app",
      "eas": {
        "projectId": "7a465cfe-d581-4bd5-bc0d-caff7c8a4a94"
      }
    },
    "owner": "barthaz"
  }
}
